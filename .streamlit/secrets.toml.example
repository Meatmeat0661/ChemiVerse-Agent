# Streamlit Cloud Secrets（share.streamlit.io → Settings → Secrets）

[data]
molecules_path = "data/chemiverse_species.json"
reactions_path = "data/chemiverse_reactions.json"

# 远程 Westlake 模拟 API（访客不用装 westlake，图在服务器上算）
[simulation_api]
base_url = "https://你的模拟服务器域名或IP:8765"
api_key = "自行设置的密钥，与服务器环境变量 SIMULATION_API_KEY 一致"
